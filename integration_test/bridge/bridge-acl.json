{
    "tagOwners": {
        "tag:bridge": ["autogroup:admin"],
        "tag:bridge-svc": ["tag:bridge"],
        "tag:user": ["autogroup:admin"]
    },
    "autoApprovers": {
        "services": {
            "svc:*": ["tag:bridge"]
        }
    },
    "grants": [
        {
            "src": ["tag:user"],
            "dst": ["tag:bridge-svc", "tag:bridge"],
            "ip": ["*"]
        }
    ]
}
