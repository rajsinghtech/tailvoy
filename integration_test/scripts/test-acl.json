{
  "tagOwners": {
    "tag:user": [],
    "tag:docker": [],
    "tag:docker-svc": ["tag:docker"],
    "tag:kind": [],
    "tag:kind-svc": ["tag:kind"]
  },
  "autoApprovers": {
    "services": {
      "svc:web": ["tag:docker"],
      "svc:docker-http": ["tag:docker"],
      "svc:docker-grpc": ["tag:docker"],
      "svc:docker-tls": ["tag:docker"],
      "svc:docker-tcp": ["tag:docker"],
      "svc:docker-udp": ["tag:docker"],
      "svc:docker-restricted": ["tag:docker"],
      "svc:docker-http-alias": ["tag:docker"],
      "svc:kind-http": ["tag:kind"],
      "svc:kind-tcp": ["tag:kind"],
      "svc:kind-grpc": ["tag:kind"],
      "svc:kind-tls": ["tag:kind"],
      "svc:kind-http-alias": ["tag:kind"]
    }
  },
  "grants": [
    {
      "src": ["tag:user"],
      "dst": ["tag:docker-svc", "tag:docker"],
      "ip": ["*"],
      "app": {
        "rajsingh.info/cap/tailvoy": [
          {"listeners": ["http"], "routes": ["/public/*", "/health", "/api/*"]},
          {"listeners": ["http"], "hostnames": ["app.tailvoy.test"], "routes": ["/*"]},
          {"listeners": ["http"], "hostnames": ["api.tailvoy.test"], "routes": ["/v1/*"]},
          {"listeners": ["tcp"]},
          {"listeners": ["tls"], "hostnames": ["secure.tailvoy.test"]},
          {"listeners": ["udp"]},
          {"listeners": ["grpc"], "routes": ["/grpc.health.v1.Health/*"]}
        ]
      }
    },
    {
      "src": ["tag:user"],
      "dst": ["tag:kind-svc", "tag:kind"],
      "ip": ["*"],
      "app": {
        "rajsingh.info/cap/tailvoy": [
          {"listeners": ["http", "default/eg/http"], "hostnames": ["public.tailvoy.test"], "routes": ["/api/*", "/health"]},
          {"listeners": ["http", "default/eg/http"], "routes": ["/public/*", "/health"]},
          {"listeners": ["grpc", "default/eg/grpc"], "routes": ["/grpc.health.v1.Health/*"]},
          {"listeners": ["tcp", "tls", "default/eg/tcp", "default/eg/tls"]}
        ]
      }
    }
  ]
}
